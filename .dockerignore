# ── Version control ───────────────────────────────────────────────────────────
.git
.github
.gitignore

# ── Python runtime artifacts ──────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv
venv
env

# ── Data & logs (mounted as volumes at runtime) ───────────────────────────────
data/
logs/

# ── Next.js frontend (deployed separately to Vercel) ─────────────────────────
frontend/

# ── Secrets (NEVER bake into the image) ──────────────────────────────────────
.env
.env.*
!.env.example

# ── Dev tooling & notebooks ───────────────────────────────────────────────────
.vscode
.idea
.ruff_cache
.pytest_cache
.coverage
htmlcov/
tests/
notebooks/
*.ipynb

# ── Documentation ─────────────────────────────────────────────────────────────
*.md
!README.md

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────────────────────
mylist.xlsx
*.bak
*.swp
*.swo
deploy/
